# Environment Variables for Digital Cassette Backend

# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/digitalcassette
DATABASE_ECHO=False

# Security
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=43200

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# CORS
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080,https://digitalcassette.app

# App Config
APP_NAME=Digital Cassette
APP_VERSION=1.0.0
DEBUG=True

# File Upload
MAX_UPLOAD_SIZE=10485760
UPLOAD_DIR=uploads/
